            Instance.new("UICorner", DropdownContainer)
            
            local DropdownStroke = Instance.new("UIStroke", DropdownContainer)
            DropdownStroke.Color = Color3.fromRGB(150, 150, 150)
            DropdownStroke.Thickness = 1
            DropdownStroke.Transparency = 0.5
            DropdownStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

            local DropdownBtn = Instance.new("TextButton")
            DropdownBtn.Parent = DropdownContainer
            DropdownBtn.BackgroundTransparency = 1
            DropdownBtn.Size = UDim2.new(1, 0, 0, 35)
            DropdownBtn.Font = Enum.Font.Gotham
            DropdownBtn.Text = "  " .. DropdownText .. " : Select Option"
            DropdownBtn.TextSize = 14
            DropdownBtn.TextXAlignment = Enum.TextXAlignment.Left
            DropdownBtn.TextTruncate = Enum.TextTruncate.AtEnd
            ApplyTextColor(DropdownBtn)

            local LineSeparator = Instance.new("Frame")
            LineSeparator.Parent = DropdownBtn
            LineSeparator.BackgroundColor3 = Color3.fromRGB(150, 150, 150)
            LineSeparator.BackgroundTransparency = 0.5
            LineSeparator.BorderSizePixel = 0
            LineSeparator.Position = UDim2.new(1, -35, 0.2, 0)
            LineSeparator.Size = UDim2.new(0, 1, 0.6, 0)

            local ArrowIcon = Instance.new("TextLabel")
            ArrowIcon.Parent = DropdownBtn
            ArrowIcon.BackgroundTransparency = 1
            ArrowIcon.Position = UDim2.new(1, -30, 0, 0)
            ArrowIcon.Size = UDim2.new(0, 30, 1, 0)
            ArrowIcon.Font = Enum.Font.GothamBold
            ArrowIcon.Text = "▼"
            ArrowIcon.TextSize = 12
            ApplyTheme(ArrowIcon, "TextColor3")

            local OptionList = Instance.new("Frame")
            OptionList.Parent = DropdownContainer
            OptionList.BackgroundColor3 = Color3.fromRGB(75, 75, 75)
            OptionList.BackgroundTransparency = 0.2
            OptionList.Position = UDim2.new(0, 0, 0, 35)
            OptionList.Size = UDim2.new(1, 0, 1, -35)
            
            local ListLayout = Instance.new("UIListLayout", OptionList)
            ListLayout.SortOrder = Enum.SortOrder.LayoutOrder

            local SearchBox = Instance.new("TextBox")
            SearchBox.Parent = OptionList
            SearchBox.BackgroundColor3 = Color3.fromRGB(65, 65, 65)
            SearchBox.BorderSizePixel = 0
            SearchBox.Size = UDim2.new(1, 0, 0, 30)
            SearchBox.Font = Enum.Font.Gotham
            SearchBox.PlaceholderText = "Search in Dropdown..."
            SearchBox.Text = ""
            SearchBox.TextSize = 14
            SearchBox.TextTruncate = Enum.TextTruncate.AtEnd
            ApplyTextColor(SearchBox)

            local OptionBtns = {}
            local function UpdateSize()
                local visibleCount = 0
                for _, btn in ipairs(OptionBtns) do
                    if btn.Visible then
                        visibleCount = visibleCount + 1
                    end
                end
                local targetHeight = isOpen and (65 + (visibleCount * 30)) or 35
                TweenService:Create(DropdownContainer, TweenInfo.new(0.2), {Size = UDim2.new(0.95, 0, 0, targetHeight)}):Play()
                ArrowIcon.Text = isOpen and "▲" or "▼"
            end

            DropdownBtn.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                SearchBox.Text = ""
                for _, btn in ipairs(OptionBtns) do
                    btn.Visible = true
                end
                UpdateSize()
            end)

            SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
                local searchText = SearchBox.Text:lower()
                for _, btn in ipairs(OptionBtns) do
                    if searchText == "" or string.find(btn.Text:lower(), searchText) then
                        btn.Visible = true
                    else
                        btn.Visible = false
                    end
                end
                UpdateSize()
            end)

            for _, option in ipairs(Options) do
                local OptionBtn = Instance.new("TextButton")
                OptionBtn.Parent = OptionList
                OptionBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
                OptionBtn.BackgroundTransparency = 0.2
                OptionBtn.BorderSizePixel = 0
                OptionBtn.Size = UDim2.new(1, 0, 0, 30)
                OptionBtn.Font = Enum.Font.Gotham
                OptionBtn.Text = "  " .. option
                OptionBtn.TextXAlignment = Enum.TextXAlignment.Left
                OptionBtn.TextSize = 14
                OptionBtn.TextTruncate = Enum.TextTruncate.AtEnd
                ApplyTextColor(OptionBtn)
                table.insert(OptionBtns, OptionBtn)

                OptionBtn.MouseEnter:Connect(function()
                    OptionBtn.BackgroundColor3 = Color3.fromRGB(95, 95, 95)
                end)
                
                OptionBtn.MouseLeave:Connect(function()
                    OptionBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
                end)

                OptionBtn.MouseButton1Click:Connect(function()
                    DropdownBtn.Text = "  " .. DropdownText .. " : " .. option
                    isOpen = false
                    UpdateSize()
                    if Callback then
                        Callback(option)
                    end
                end)
            end
        end
        
        return CategoryElements
    end
    
    return WindowElements
