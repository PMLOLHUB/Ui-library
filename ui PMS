    SidebarList.HorizontalAlignment = Enum.HorizontalAlignment.Center
    
    local SidebarPadding = Instance.new("UIPadding", Sidebar)
    SidebarPadding.PaddingTop = UDim.new(0, 10)
    
    SidebarList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        Sidebar.CanvasSize = UDim2.new(0, 0, 0, SidebarList.AbsoluteContentSize.Y + 20)
    end)
    
    local ContentContainer = Instance.new("Frame")
    ContentContainer.Name = "ContentContainer"
    ContentContainer.Parent = MainFrame
    ContentContainer.BackgroundTransparency = 1
    ContentContainer.Position = UDim2.new(0.29, 0, 0.12, 0)
    ContentContainer.Size = UDim2.new(0.69, 0, 0.84, 0)
    ContentContainer.ZIndex = 2
    
    local WindowElements = {}
    
    function WindowElements:CreateCategory(CategoryName, IconName)
        local CategoryElements = {}
        local CategoryBtn = Instance.new("TextButton")
        CategoryBtn.Parent = Sidebar
        CategoryBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
        CategoryBtn.BackgroundTransparency = 0.3
        CategoryBtn.Size = UDim2.new(0.9, 0, 0, 30)
        CategoryBtn.Font = Enum.Font.GothamBold
        CategoryBtn.Text = CategoryName
        CategoryBtn.TextSize = 14
        CategoryBtn.TextTruncate = Enum.TextTruncate.AtEnd
        CategoryBtn.ZIndex = 3
        Instance.new("UICorner", CategoryBtn)
        ApplyTextColor(CategoryBtn)
        
        -- Note: If you have an Icons table, make sure it's defined before calling this
        if IconName and Icons and Icons[IconName] then
            CategoryBtn.TextXAlignment = Enum.TextXAlignment.Left
            local UIPad = Instance.new("UIPadding", CategoryBtn)
            UIPad.PaddingLeft = UDim.new(0, 35)
            local IconImg = Instance.new("ImageLabel")
            IconImg.Parent = CategoryBtn
            IconImg.BackgroundTransparency = 1
            IconImg.Position = UDim2.new(0, -25, 0.5, -10)
            IconImg.Size = UDim2.new(0, 20, 0, 20)
            IconImg.Image = Icons[IconName]
            ApplyTextColor(IconImg, "ImageColor3")
        end
        
        local CategoryPage = Instance.new("ScrollingFrame")
        CategoryPage.Parent = ContentContainer
        CategoryPage.BackgroundTransparency = 1
        CategoryPage.Size = UDim2.new(1, 0, 1, 0)
        CategoryPage.ScrollBarThickness = 4
        CategoryPage.Visible = false
        CategoryPage.CanvasSize = UDim2.new(0, 0, 0, 0)
        CategoryPage.ZIndex = 3
        
        local PageLayout = Instance.new("UIListLayout", CategoryPage)
        PageLayout.SortOrder = Enum.SortOrder.LayoutOrder
        PageLayout.Padding = UDim.new(0, 5)
        PageLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        
        local PagePadding = Instance.new("UIPadding", CategoryPage)
        PagePadding.PaddingTop = UDim.new(0, 5)
        
        PageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            CategoryPage.CanvasSize = UDim2.new(0, 0, 0, PageLayout.AbsoluteContentSize.Y + 20)
        end)
        
        local function SelectTab()
            for _, page in pairs(ContentContainer:GetChildren()) do
                if page:IsA("ScrollingFrame") then
                    page.Visible = false
                end
            end
            for _, btn in pairs(Sidebar:GetChildren()) do
                if btn:IsA("TextButton") then
                    btn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
                end
            end
            CategoryPage.Visible = true
            TweenService:Create(CategoryBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(100, 100, 100)}):Play()
        end
        
        CategoryBtn.MouseButton1Click:Connect(SelectTab)
        if isFirstTab then
            SelectTab()
            isFirstTab = false
        end
        
        function CategoryElements:CreateLabel(Text, TextColor)
