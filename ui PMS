    ToggleBtn.BackgroundTransparency = 0.2
    ToggleBtn.Position = UDim2.new(0, 20, 0, 20)
    ToggleBtn.Size = UDim2.new(0, 50, 0, 50)
    ToggleBtn.AutoButtonColor = true
    Instance.new("UICorner", ToggleBtn).CornerRadius = UDim.new(1, 0)
    Instance.new("UIStroke", ToggleBtn).Thickness = 2
    
    if ToggleConfig.Image and ToggleConfig.Image ~= "" then
        ToggleBtn.Image = ToggleConfig.Image
        ToggleBtn.ImageRectSize = Vector2.new(0, 0)
    else
        ToggleBtn.ImageTransparency = 1
    end
    
    local ToggleText = Instance.new("TextLabel")
    ToggleText.Parent = ToggleBtn
    ToggleText.BackgroundTransparency = 1
    ToggleText.Size = UDim2.new(1, 0, 1, 0)
    ToggleText.Font = Enum.Font.GothamBold
    ToggleText.Text = ToggleConfig.Text or (ToggleConfig.Image and "" or "UI")
    ToggleText.TextSize = 16
    ToggleText.TextTruncate = Enum.TextTruncate.AtEnd
    ApplyTextColor(ToggleText)
    MakeDraggable(ToggleBtn)
    
    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Parent = ScreenGui
    MainFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    MainFrame.BackgroundTransparency = 0.1
